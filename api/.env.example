# --- Application ---
NODE_ENV=development
APP_VERSION=0.1.0
PORT=3000
NODE_ID=node-1
LOG_LEVEL=info
MEKO_BASE_URL=http://localhost:3000

# --- Database ---
# App connects through PgBouncer (transaction pool mode).
DATABASE_URL=postgres://meko:meko@localhost:6432/meko
# Migrator + any session-level advisory lock / LISTEN-NOTIFY MUST bypass PgBouncer (§3d/3h).
POSTGRES_DIRECT_URL=postgres://meko:meko@localhost:5432/meko

# --- Redis (pub/sub bus, WS ticket store, rate-limit store) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-in-prod-min-32-bytes-long-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
WS_TICKET_TTL_SECONDS=10

# --- CORS / CSRF (§5g, §12l) ---
# Comma-separated. Used for both CORS and WebSocket Origin validation.
MEKO_ALLOWED_ORIGINS=http://localhost:3000

# --- OIDC login (Authentik) ---
# Optional. Leave OIDC_ISSUER empty to disable — the /api/auth/oidc/* routes 404 when unset.
# The IdP authenticates the user; meko still issues its own rotating refresh-cookie session.
# OIDC_ISSUER=https://authentik.example.com/application/o/meko
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3000/api/auth/oidc/callback
# Where the callback sends the browser after a successful login (the SPA origin).
MEKO_WEB_URL=http://localhost:5173

# --- Limits (§4e) ---
MEKO_MAX_BOARD_BYTES=52428800
MEKO_SNAPSHOT_RETENTION=3
ROUTE_TIMEOUT_MS=10000

# --- Media / S3-compatible object store (RustFS / MinIO / S3) ---
# Leave S3_ENDPOINT empty to disable media uploads. Path-style addressing is used.
S3_ENDPOINT=https://rustfs.example.com
# Optional split: app reaches storage over LAN, browser fetches presigned URLs over a public host.
# Presigned URLs are signed for S3_ENDPOINT_PUBLIC (SigV4 binds the host); data ops use INTERNAL.
# Both default to S3_ENDPOINT when unset.
S3_ENDPOINT_INTERNAL=
S3_ENDPOINT_PUBLIC=
S3_REGION=us-east-1
S3_BUCKET=meko
S3_ACCESS_KEY=
S3_SECRET_KEY=
MEKO_MAX_UPLOAD_BYTES=26214400
