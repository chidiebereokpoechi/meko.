# --- Application ---
NODE_ENV=development
APP_VERSION=0.1.0
PORT=3000
NODE_ID=node-1
LOG_LEVEL=info
MEKO_BASE_URL=http://localhost:3000

# --- Database ---
# App connects through PgBouncer (transaction pool mode).
DATABASE_URL=postgres://meko:meko@localhost:6432/meko
# Migrator + any session-level advisory lock / LISTEN-NOTIFY MUST bypass PgBouncer (§3d/3h).
POSTGRES_DIRECT_URL=postgres://meko:meko@localhost:5432/meko

# --- Redis (pub/sub bus, WS ticket store, rate-limit store) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-in-prod-min-32-bytes-long-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
WS_TICKET_TTL_SECONDS=10

# --- CORS / CSRF (§5g, §12l) ---
# Comma-separated. Used for both CORS and WebSocket Origin validation.
MEKO_ALLOWED_ORIGINS=http://localhost:3000

# --- Limits (§4e) ---
MEKO_MAX_BOARD_BYTES=52428800
MEKO_SNAPSHOT_RETENTION=3
ROUTE_TIMEOUT_MS=10000

# --- Media / S3 ---
S3_ENDPOINT=
S3_BUCKET=meko
S3_ACCESS_KEY=
S3_SECRET_KEY=
